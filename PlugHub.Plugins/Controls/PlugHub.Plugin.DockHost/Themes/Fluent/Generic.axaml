<Styles xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:av="using:Avalonia.Controls"
		xmlns:an="using:Avalonia.Animation"
		xmlns:i="using:Avalonia.Xaml.Interactivity"
		xmlns:dnd="using:Avalonia.Xaml.Interactions.Draggable"
		xmlns:local="clr-namespace:PlugHub.Plugin.DockHost.Controls"
		xmlns:behav="clr-namespace:PlugHub.Plugin.DockHost.Behaviors">

	<Styles.Resources>
		<DrawingBrush
			x:Key="CustomGridBrush"
			TileMode="Tile"
			Stretch="None"
			DestinationRect="0,0,4,8">
			<DrawingBrush.Drawing>
				<DrawingGroup>
					<!-- Transparent background -->
					<GeometryDrawing Brush="Transparent">
						<GeometryDrawing.Geometry>
							<RectangleGeometry Rect="0,0,4,8" />
						</GeometryDrawing.Geometry>
					</GeometryDrawing>
					<GeometryDrawing Brush="{DynamicResource TextFillColorDisabledBrush}">
						<GeometryDrawing.Geometry>
							<GeometryGroup>
								<RectangleGeometry Rect="1,1,1,1" />
								<RectangleGeometry Rect="1,3,1,1" />
								<RectangleGeometry Rect="1,5,1,1" />
								<RectangleGeometry Rect="1,7,1,1" />
							</GeometryGroup>
						</GeometryDrawing.Geometry>
					</GeometryDrawing>
					<GeometryDrawing Brush="{DynamicResource TextFillColorDisabledBrush}">
						<GeometryDrawing.Geometry>
							<GeometryGroup>
								<RectangleGeometry Rect="3,2,1,1" />
								<RectangleGeometry Rect="3,4,1,1" />
								<RectangleGeometry Rect="3,6,1,1" />
							</GeometryGroup>
						</GeometryDrawing.Geometry>
					</GeometryDrawing>
				</DrawingGroup>
			</DrawingBrush.Drawing>
		</DrawingBrush>
	</Styles.Resources>

	<!-- Custom Styles -->

	<!-- ResizablePanel Styles -->
	<Style Selector="local|ResizablePanel Thumb">
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate>
					<Border Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}" />
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ContentSwitcher Styles -->
	<Style Selector="local|ContentSwitcher:pointerover:edge-left Border.accent-bar">
		<Setter Property="BorderThickness" Value="0,0,0,4"/>
	</Style>
	<Style Selector="local|ContentSwitcher:pointerover:edge-right Border.accent-bar">
		<Setter Property="BorderThickness" Value="0,4,0,0"/>
	</Style>
	<Style Selector="local|ContentSwitcher:pointerover:edge-top Border.accent-bar">
		<Setter Property="BorderThickness" Value="0,4,0,0"/>
	</Style>
	<Style Selector="local|ContentSwitcher:pointerover:edge-bottom Border.accent-bar">
		<Setter Property="BorderThickness" Value="0,0,0,4"/>
	</Style>

	<!-- ContentSwitcherItem Styles -->
	<Style Selector="Button.content-item">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="BorderThickness" Value="0"/>
	</Style>
	<Style Selector="Button.content-item:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="Transparent"/>
	</Style>
	<Style Selector="Button.content-item .accent-bar" x:SetterTargetType="Border">
		<Setter Property="Opacity" Value="0"/>
		<Setter Property="Transitions">
			<Transitions>
				<DoubleTransition Property="Opacity" Duration="0:0:0.30"/>
			</Transitions>
		</Setter>
	</Style>
	<Style Selector="Button.content-item:pointerover .accent-bar" x:SetterTargetType="Border">
		<Setter Property="Opacity" Value="1"/>
	</Style>

	<!-- DockablePanel Styles -->
	<Style Selector="Grid.path-button:pointerover">
		<Setter Property="Background" Value="{DynamicResource ControlStrongFillColorDefaultBrush}"/>
	</Style>
	<Style Selector="Grid.path-button-close:pointerover">
		<Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
	</Style>
	<Style Selector="Grid.path-button:pointerover Path,
                 Grid.path-button-close:pointerover Path">
		<Setter Property="Stroke" Value="{DynamicResource TextFillColorInverseBrush}"/>
		<Setter Property="Fill" Value="{DynamicResource TextFillColorInverseBrush}"/>
	</Style>

	<Style Selector="local|DockablePanel:unpinned /template/ #PART_ButtonPin"
		   x:SetterTargetType="Grid">
		<Setter Property="IsVisible" Value="True"/>
	</Style>
	<Style Selector="local|DockablePanel:pinned /template/ #PART_ButtonPin"
		   x:SetterTargetType="Grid">
		<Setter Property="IsVisible" Value="False"/>
	</Style>

	<Style Selector="local|DockablePanel:pinned /template/ #PART_ButtonUnpin"
		   x:SetterTargetType="Grid">
		<Setter Property="IsVisible" Value="True"/>
	</Style>
	<Style Selector="local|DockablePanel:unpinned /template/ #PART_ButtonUnpin"
		   x:SetterTargetType="Grid">
		<Setter Property="IsVisible" Value="False"/>
	</Style>
	<Style Selector="local|DockablePanel:nonclosable /template/ #PART_ButtonClose"
		   x:SetterTargetType="Grid">
		<Setter Property="IsVisible" Value="False"/>
	</Style>
	<Style Selector="local|DockablePanel:closable /template/ #PART_ButtonClose"
		   x:SetterTargetType="Grid">
		<Setter Property="IsVisible" Value="True"/>
	</Style>


	<!--DockControl Styles -->
	<Style Selector="local|DockControl TabControl[TabStripPlacement=Bottom] TabItem">
		<Setter Property="Padding" Value="0"/>
		<Setter Property="Margin" Value="0"/>
	</Style>
	<Style Selector="local|DockControl TabControl[TabStripPlacement=Bottom] TabItem:selected /template/ #PART_SelectedPipe" x:SetterTargetType="Rectangle">
		<Setter Property="IsVisible" Value="False"/>
	</Style>
	<Style Selector="local|DockControl TabControl[TabStripPlacement=Bottom] /template/ ItemsPresenter#PART_ItemsPresenter" x:SetterTargetType="ItemsPresenter">
		<Setter Property="MaxHeight" Value="24"/>
	</Style>
	<Style Selector="local|DockControl TabControl[TabStripPlacement=Bottom] TabItem">
		<Setter Property="MinHeight" Value="24"/>
		<Setter Property="MinWidth" Value="64"/>
		<Setter Property="Template">
			<ControlTemplate>
				<Border Name="HeaderBorder"
						BorderBrush="Transparent"
						BorderThickness="0"
						Background="Transparent"
						Padding="4,0"
						Margin="0"
						VerticalAlignment="Center">
					<ContentPresenter
						Content="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
						ContentTemplate="{TemplateBinding HeaderTemplate}"
						VerticalAlignment="Center"
						HorizontalAlignment="Center"/>
				</Border>
			</ControlTemplate>
		</Setter>
	</Style>
	<Style Selector="local|DockControl TabControl[TabStripPlacement=Top] TabItem">
		<Setter Property="MinHeight" Value="24"/>
		<Setter Property="MinWidth" Value="64"/>
		<Setter Property="Template">
			<ControlTemplate>
				<Border Name="HeaderBorder"
						BorderBrush="Transparent"
						BorderThickness="0"
						Background="Transparent"
						Padding="4,0"
						Margin="0"
						VerticalAlignment="Center">
					<ContentPresenter
						Content="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
						ContentTemplate="{TemplateBinding HeaderTemplate}"
						VerticalAlignment="Center"
						HorizontalAlignment="Center"/>
				</Border>
			</ControlTemplate>
		</Setter>
	</Style>
	<Style Selector="local|DockControl TabControl TabItem:selected /template/ Border#HeaderBorder">
		<Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}"/>
		<Setter Property="BorderBrush" Value="Black"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Margin" Value="0"/>
	</Style>
	<Style Selector="local|DockControl /template/ #PART_DropTargetsGrid > Border.DropTarget.IsPointerOver">
		<Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
		<Setter Property="Opacity" Value="0.5"/>
	</Style>


	<!-- Main Templates -->

	<!-- ResizablePanel -->
	<Style Selector="local|ResizablePanel">
		<Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}"/>
		<Setter Property="ThumbBrush" Value="{DynamicResource AccentFillColorTertiaryBrush}"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate>
					<Grid
						IsVisible="{TemplateBinding IsVisible}"
						Background="{TemplateBinding Background}">
						<ContentPresenter
							Name="PART_ContentPresenter"
							Content="{TemplateBinding Content}"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"/>
						<Thumb
							Name="PART_ResizeThumb"
							Background="{TemplateBinding ThumbBrush}"/>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- RotatableContent -->
	<Style Selector="local|RotatableContent">
		<Setter Property="Template">
			<ControlTemplate>
				<LayoutTransformControl>
					<LayoutTransformControl.LayoutTransform>
						<RotateTransform Angle="{Binding Rotation, RelativeSource={RelativeSource TemplatedParent}}" />
					</LayoutTransformControl.LayoutTransform>

					<ContentPresenter
					  Name="PART_ContentPresenter"
					  Content="{TemplateBinding Content}"
					  ContentTemplate="{TemplateBinding ContentTemplate}"
					  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
					  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
				</LayoutTransformControl>
			</ControlTemplate>
		</Setter>
	</Style>

	<!-- ContentSwitcher -->
	<Style Selector="local|ContentSwitcher">

		<Setter Property="Template">
			<ControlTemplate>
				<ScrollViewer
					Name="PART_ContentItemScroller"
					HorizontalScrollBarVisibility="Hidden"
					VerticalScrollBarVisibility="Hidden"
					ClipToBounds="True">
					<ItemsPresenter
						Name="PART_ContentItemStrip"
						DockPanel.Dock="{TemplateBinding DockEdge}"
						ItemsPanel="{TemplateBinding ItemsPanel}"/>
				</ScrollViewer>
			</ControlTemplate>
		</Setter>

		<Setter Property="ItemsPanel">
			<Setter.Value>
				<ItemsPanelTemplate>
					<StackPanel Orientation="{Binding Orientation, RelativeSource={RelativeSource AncestorType=local:ContentSwitcher}}" />
				</ItemsPanelTemplate>
			</Setter.Value>
		</Setter>

		<Setter Property="ItemTemplate">
			<Setter.Value>
				<DataTemplate>
					<local:RotatableContent
						Rotation="{Binding Rotation, RelativeSource={RelativeSource AncestorType=local:ContentSwitcher}}"
						Tag="{Binding}">
						<ContentPresenter
							Content="{Binding}"
							ContentTemplate="{Binding ContentItemTemplate, RelativeSource={RelativeSource AncestorType=local:ContentSwitcher}}" />
					</local:RotatableContent>
				</DataTemplate>
			</Setter.Value>
		</Setter>

		<!-- ContentItemTemplate -->
		<Setter Property="ContentItemTemplate">
			<Setter.Value>
				<DataTemplate>
					<Button Classes="content-item" Tag="{Binding}" Padding="0,5,11,6">
						<Grid>
							<TextBlock
								Text="{Binding Header}"
								FontSize="14"
								FontWeight="Thin"
								HorizontalAlignment="Center"
								Margin="0,4,0,4" />
							<Border
								BorderBrush="{DynamicResource TextFillColorDisabledBrush}"/>
							<Border
								Classes="accent-bar"
								BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"/>
						</Grid>
					</Button>
				</DataTemplate>
			</Setter.Value>
		</Setter>

	</Style>

	<!-- DockablePanel -->
	<Style Selector="local|DockablePanel">
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="BorderBrush" Value="Black"/>
		<Setter Property="Background" Value="{DynamicResource SystemFillColorSolidNeutralBackgroundBrush}"/>
		<Setter Property="Padding" Value="0"/>
		<Setter Property="Margin" Value="0"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate>
					<Border
						BorderThickness="{TemplateBinding BorderThickness}"
						BorderBrush="{TemplateBinding BorderBrush}"
						Background="{TemplateBinding Background}"
						Padding="{TemplateBinding Padding}"
						Margin="{TemplateBinding Margin}">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="2"/>
								<RowDefinition Height="16"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<Border
							  Grid.Row="0"
							  Background="{DynamicResource AccentFillColorDisabledBrush}"
							  HorizontalAlignment="Stretch"
							  VerticalAlignment="Stretch"/>

							<Grid Grid.Row="1">
								<Grid.RowDefinitions>
									<RowDefinition Height="24"/>
								</Grid.RowDefinitions>

								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<TextBlock
									Grid.Row="0" Grid.Column="0"
									Text="{TemplateBinding Header}"
									FontSize="16"
									FontWeight="Light"
									Margin="4,0,0,0"/>

								<Border
									Grid.Row="0" Grid.Column="1"
									Margin="4,0,4,0"
									HorizontalAlignment="Stretch"
									VerticalAlignment="Center"
									Height="8"
									Background="{StaticResource CustomGridBrush}"/>

								<StackPanel
									Grid.Row="0"
									Grid.Column="2"
									Orientation="Horizontal"
									Margin="0,0,8,0"
									HorizontalAlignment="Right">

									<!-- Pin -->
									<Grid Name="PART_ButtonPin"
										  Classes="path-button"
										  Width="16" Height="16">
										<!-- Visual -->
										<Path HorizontalAlignment="Center"
											  VerticalAlignment="Center"
											  Stroke="{DynamicResource TextFillColorPrimaryBrush}"
											  Fill="{DynamicResource TextFillColorPrimaryBrush}"
											  StrokeThickness="1"
											  Data="M6 4H12V9H6ZM0 6H4V7H0ZM4 2H6V11H4Z"/>
										<!-- Overlay -->
										<Border Name="PART_ButtonPinOverlay"
												Background="Transparent"
												IsHitTestVisible="True"
												ZIndex="1000"/>
									</Grid>

									<!-- Unpin -->
									<Grid Name="PART_ButtonUnpin"
										  Classes="path-button"
										  Width="16" Height="16">
										<!-- Visual -->
										<Path HorizontalAlignment="Center"
											  VerticalAlignment="Center"
											  Stroke="{DynamicResource TextFillColorPrimaryBrush}"
											  Fill="{DynamicResource TextFillColorPrimaryBrush}"
											  StrokeThickness="1"
											  Data="M4 8V2H9V8Zm2 4V10H7v2ZM2 10V8h9v2Z"/>
										<!-- Overlay -->
										<Border Name="PART_ButtonUnpinOverlay"
												Background="Transparent"
												IsHitTestVisible="True"
												ZIndex="1000"/>
									</Grid>

									<!-- Close -->
									<Grid Name="PART_ButtonClose"
										  Classes="path-button-close"
										  Width="16" Height="16">
										<!-- Visual -->
										<Path Stroke="{DynamicResource TextFillColorPrimaryBrush}"
											  StrokeThickness="4"
											  Data="M4,4 L12,12 M12,4 L4,12"/>
										<!-- Overlay -->
										<Border Name="PART_ButtonCloseOverlay"
												Background="Transparent"
												IsHitTestVisible="True"
												ZIndex="1000"/>
									</Grid>

								</StackPanel>

								<Border
									Name="PART_DragHandle"
									Grid.Row="0"
									Grid.Column="0"
									Grid.ColumnSpan="2"
									HorizontalAlignment="Stretch"
									VerticalAlignment="Stretch"
									Background="Transparent"/>
							</Grid>

							<ContentPresenter
								Grid.Row="2"
								Name="PART_ContentPresenter"
								Content="{TemplateBinding Content}"/>
						</Grid>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>



	<!-- DockCompass -->
	<Style Selector="local|DockCompass">
		<Setter Property="Template">
			<ControlTemplate>
				<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
					<!-- Bottom layer: large highlight regions -->
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="1*" />
							<RowDefinition Height="3*" />
							<RowDefinition Height="1*" />
						</Grid.RowDefinitions>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="1*" />
							<ColumnDefinition Width="3*" />
							<ColumnDefinition Width="1*" />
						</Grid.ColumnDefinitions>

						<Border Name="PART_NorthRegion" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="Transparent"/>
						<Border Name="PART_SouthRegion" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="Transparent"/>
						<Border Name="PART_WestRegion" Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Background="Transparent"/>
						<Border Name="PART_EastRegion" Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" Background="Transparent"/>
					</Grid>

					<!-- Top layer: centered petal grid with hit cells -->
					<Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="200" Height="200">
						<Grid.RowDefinitions>
							<RowDefinition Height="*" />
							<RowDefinition Height="*" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<!-- North cell (hit target + icon) -->
						<Border Name="PART_NorthCell"
								Grid.Row="0" Grid.Column="1"
								BorderBrush="{DynamicResource TextFillColorPrimaryBrush}"
								BorderThickness="1">
							<Border Background="#40FFFFFF">
								<PathIcon Width="32" Height="32" Data="M 10 10 L 110 10 L 110 110 L 10 110 Z M 20 30 L 100 30 L 100 100 L 20 100 Z"/>
							</Border>
						</Border>

						<!-- South cell -->
						<Border Name="PART_SouthCell"
								Grid.Row="2" Grid.Column="1"
								BorderBrush="{DynamicResource TextFillColorPrimaryBrush}"
								BorderThickness="1">
							<Border Background="#40FFFFFF">
								<PathIcon Width="32" Height="32" Data="M 10 10 L 110 10 L 110 110 L 10 110 Z M 20 20 L 100 20 L 100 90 L 20 90 Z"/>
							</Border>
						</Border>

						<!-- West cell -->
						<Border Name="PART_WestCell"
								Grid.Row="1" Grid.Column="0"
								BorderBrush="{DynamicResource TextFillColorPrimaryBrush}"
								BorderThickness="1">
							<Border Background="#40FFFFFF">
								<PathIcon Width="32" Height="32" Data="M 10 10 L 110 10 L 110 110 L 10 110 Z M 30 20 L 100 20 L 100 100 L 30 100 Z"/>
							</Border>
						</Border>

						<!-- East cell -->
						<Border Name="PART_EastCell"
								Grid.Row="1" Grid.Column="2"
								BorderBrush="{DynamicResource TextFillColorPrimaryBrush}"
								BorderThickness="1">
							<Border Background="#40FFFFFF">
								<PathIcon Width="32" Height="32" Data="M 10 10 L 110 10 L 110 110 L 10 110 Z M 20 20 L 90 20 L 90 100 L 20 100 Z"/>
							</Border>
						</Border>

						<!-- Center (disabled) -->
						<Border Grid.Row="1" Grid.Column="1" Background="Transparent" IsHitTestVisible="False"/>
					</Grid>
				</Grid>
			</ControlTemplate>
		</Setter>
	</Style>

	<!-- Top edge highlight -->
	<Style Selector="local|DockCompass:edge-top /template/ #PART_NorthRegion"
		   x:SetterTargetType="Border">
		<Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
	</Style>

	<!-- Bottom edge highlight -->
	<Style Selector="local|DockCompass:edge-bottom /template/ #PART_SouthRegion"
		   x:SetterTargetType="Border">
		<Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
	</Style>

	<!-- Left edge highlight -->
	<Style Selector="local|DockCompass:edge-left /template/ #PART_WestRegion"
		   x:SetterTargetType="Border">
		<Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
	</Style>

	<!-- Right edge highlight -->
	<Style Selector="local|DockCompass:edge-right /template/ #PART_EastRegion"
		   x:SetterTargetType="Border">
		<Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
	</Style>



	<!-- DockControl -->
	<Style Selector="local|DockControl">

		<Setter Property="Template">
			<ControlTemplate TargetType="local:DockControl">
				<Grid>
					<!-- Base layout -->
					<DockPanel Name="PART_RootDockPanel">

						<!-- Left Gutter -->
						<local:ContentSwitcher
							Name="PART_LeftGutter"
							DockEdge="Left"
							DockPanel.Dock="Left"
							VerticalAlignment="Stretch"
							Margin="{TemplateBinding LeftGutterMargins}"
							IsVisible="{Binding HasItems, RelativeSource={RelativeSource Self}}"/>

						<!-- Top Gutter -->
						<local:ContentSwitcher
							Name="PART_TopGutter"
							DockEdge="Top"
							DockPanel.Dock="Top"
							HorizontalAlignment="Stretch"
							Margin="{TemplateBinding TopGutterMargins}"
							IsVisible="{Binding HasItems, RelativeSource={RelativeSource Self}}"/>

						<!-- Right Gutter -->
						<local:ContentSwitcher
							Name="PART_RightGutter"
							DockEdge="Right"
							DockPanel.Dock="Right"
							VerticalAlignment="Stretch"
							Margin="{TemplateBinding RightGutterMargins}"
							IsVisible="{Binding HasItems, RelativeSource={RelativeSource Self}}"/>

						<!-- Bottom Gutter -->
						<local:ContentSwitcher
							Name="PART_BottomGutter"
							DockEdge="Bottom"
							DockPanel.Dock="Bottom"
							HorizontalAlignment="Stretch"
							Margin="{TemplateBinding BottomGutterMargins}"
							IsVisible="{Binding HasItems, RelativeSource={RelativeSource Self}}"/>

						<Grid Name="PART_RootGrid">

							<Grid.RowDefinitions>
								<RowDefinition Height="{TemplateBinding TopPanelLength}"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="{TemplateBinding BottomPanelLength}"/>
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="{TemplateBinding LeftPanelLength}"/>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="{TemplateBinding RightPanelLength}"/>
							</Grid.ColumnDefinitions>

							<!-- Top pinned -->
							<Border
								Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								ClipToBounds="True"
								IsVisible="{TemplateBinding HasTopContent}">

								<ContentPresenter
									Name="PART_TopPinnedPresenter"
									Content="{Binding TopPinned, RelativeSource={RelativeSource TemplatedParent}}"
									ContentTemplate="{TemplateBinding DockControlTopTabControl}" />
							</Border>

							<!-- Top splitter -->
							<GridSplitter
								Name="PART_TopGridSplitter"
								Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5"
								Height="4"
								Background="Transparent"
								HorizontalAlignment="Stretch"
								ResizeDirection="Rows"
								IsVisible="{TemplateBinding HasTopContent}"/>

							<!-- Left pinned -->
							<Border
								Grid.Row="2" Grid.Column="0"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								ClipToBounds="True"
								IsVisible="{TemplateBinding HasLeftContent}">

								<ContentPresenter
									Name="PART_LeftPinnedPresenter"
									Content="{Binding LeftPinned, RelativeSource={RelativeSource TemplatedParent}}"
									ContentTemplate="{TemplateBinding DockControlBottomTabControl}" />
							</Border>

							<!-- Left splitter -->
							<GridSplitter
								Grid.Row="2" Grid.Column="1"
								Name="PART_LeftGridSplitter"
								Width="4"
								Background="Transparent"
								VerticalAlignment="Stretch"
								ResizeDirection="Columns"
								IsVisible="{TemplateBinding HasLeftContent}"/>

							<!-- Main content -->
							<ContentPresenter
								Grid.Row="2" Grid.Column="2"
								Content="{TemplateBinding Content}"
								ContentTemplate="{TemplateBinding ContentTemplate}" />

							<!-- Right splitter -->
							<GridSplitter
								Grid.Row="2" Grid.Column="3"
								Name="PART_RightGridSplitter"
								Width="4"
								Background="Transparent"
								VerticalAlignment="Stretch"
								ResizeDirection="Columns"
								IsVisible="{TemplateBinding HasRightContent}"/>

							<!-- Right pinned -->
							<Border
								Grid.Row="2" Grid.Column="4"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								ClipToBounds="True"
								IsVisible="{TemplateBinding HasRightContent}">

								<ContentPresenter
									Name="PART_RightPinnedPresenter"
									Content="{Binding RightPinned, RelativeSource={RelativeSource TemplatedParent}}"
									ContentTemplate="{TemplateBinding DockControlBottomTabControl}" />
							</Border>

							<!-- Bottom splitter -->
							<GridSplitter Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5"
										  Name="PART_BottomGridSplitter"
										  Height="4"
										  Background="Transparent"
										  HorizontalAlignment="Stretch"
										  ResizeDirection="Rows"
										  IsVisible="{TemplateBinding HasBottomContent}"/>

							<!-- Bottom pinned -->
							<Border
								Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								ClipToBounds="True"
								IsVisible="{TemplateBinding HasBottomContent}"
								Classes="TopTabs">

								<ContentPresenter
									Name="PART_BottomPinnedPresenter"
									Content="{Binding BottomPinned, RelativeSource={RelativeSource TemplatedParent}}"
									ContentTemplate="{TemplateBinding DockControlBottomTabControl}"/>
							</Border>

						</Grid>

					</DockPanel>

					<!-- Overlay resizers -->
					<Grid Name="PART_OverlayGrid">

						<!-- Left resizer -->
						<local:ResizablePanel
							Name="PART_LeftFlyoutPanel"
							ThumbBrush="{DynamicResource SystemAccentColor}"
							DockEdge="Left"
							IsVisible="{Binding IsOpen, ElementName=PART_LeftGutter}"
							HorizontalAlignment="Left"
							VerticalAlignment="Stretch"
							Margin="{TemplateBinding LeftFlyoutMargin}">
							<av:TransitioningContentControl
								IsTransitionReversed="True"
								Content="{Binding ActiveContent, ElementName=PART_LeftGutter}">
								<av:TransitioningContentControl.PageTransition>
									<an:CompositePageTransition/>
								</av:TransitioningContentControl.PageTransition>
							</av:TransitioningContentControl>
						</local:ResizablePanel>

						<!-- Top resizer -->
						<local:ResizablePanel
							Name="PART_TopFlyoutPanel"
							ThumbBrush="{DynamicResource SystemAccentColor}"
							DockEdge="Top"
							IsVisible="{Binding IsOpen, ElementName=PART_TopGutter}"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Top"
							Margin="{TemplateBinding TopFlyoutMargin}">
							<av:TransitioningContentControl
								IsTransitionReversed="True"
								Content="{Binding ActiveContent, ElementName=PART_TopGutter}">
								<av:TransitioningContentControl.PageTransition>
									<an:CompositePageTransition/>
								</av:TransitioningContentControl.PageTransition>
							</av:TransitioningContentControl>
						</local:ResizablePanel>

						<!-- Right resizer -->
						<local:ResizablePanel
							Name="PART_RightFlyoutPanel"
							ThumbBrush="{DynamicResource SystemAccentColor}"
							DockEdge="Right"
							IsVisible="{Binding IsOpen, ElementName=PART_RightGutter}"
							HorizontalAlignment="Right"
							VerticalAlignment="Stretch"
							Margin="{TemplateBinding RightFlyoutMargin}">
							<av:TransitioningContentControl
								IsTransitionReversed="False"
								Content="{Binding ActiveContent, ElementName=PART_RightGutter}">
								<av:TransitioningContentControl.PageTransition>
									<an:CompositePageTransition/>
								</av:TransitioningContentControl.PageTransition>
							</av:TransitioningContentControl>
						</local:ResizablePanel>

						<!-- Bottom resizer -->
						<local:ResizablePanel
							Name="PART_BottomFlyoutPanel"
							ThumbBrush="{DynamicResource SystemAccentColor}"
							DockEdge="Bottom"
							IsVisible="{Binding IsOpen, ElementName=PART_BottomGutter}"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Bottom"
							Margin="{TemplateBinding BottomFlyoutMargin}">
							<av:TransitioningContentControl
								IsTransitionReversed="False"
								Content="{Binding ActiveContent, ElementName=PART_BottomGutter}">
								<av:TransitioningContentControl.PageTransition>
									<an:CompositePageTransition/>
								</av:TransitioningContentControl.PageTransition>
							</av:TransitioningContentControl>
						</local:ResizablePanel>

					</Grid>

					<!-- Drop dropzones -->
					<local:DockCompass Name="PART_DockCompass"/>

					<Grid Name="PART_DropTargetsGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
						<!-- Left dropzone
						<Border
							Name="PART_LeftDropTarget"
							VerticalAlignment="Stretch"
							HorizontalAlignment="Left"
							Width="32"
							Margin="0,128,0,128"
							Opacity="0.25"
							Classes="DropTarget"
							IsHitTestVisible="True"/> -->
						<!-- Top dropzone
						<Border
							Name="PART_TopDropTarget"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Top"
							Height="32"
							Margin="128,0,128,0"
							Opacity="0.25"
							Classes="DropTarget"
							IsHitTestVisible="True"/> -->
						<!-- Right dropzone 
						<Border
							Name="PART_RightDropTarget"
							VerticalAlignment="Stretch"
							HorizontalAlignment="Right"
							Width="32"
							Margin="0,128,0,128"
							Opacity="0.25"
							Classes="DropTarget"
							IsHitTestVisible="True"/>-->
						<!-- Bottom dropzone 
						<Border
							Name="PART_BottomDropTarget"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Bottom"
							Height="32"
							Margin="128,0,128,0"
							Opacity="0.25"
							Classes="DropTarget"
							IsHitTestVisible="True"/>-->
					</Grid>
				</Grid>
			</ControlTemplate>
		</Setter>

		<!-- DockControlBottomTabControl -->
		<Setter Property="DockControlBottomTabControl">
			<Setter.Value>
				<DataTemplate>
					<Border Name="BottomTabBorder" Padding="0" Margin="0,0,0,4">
						<TabControl
							Classes=""
							ItemsSource="{Binding}"
							ClipToBounds="True"
							TabStripPlacement="Bottom"
							Padding="0"
							Margin="0">

							<i:Interaction.Behaviors>
								<behav:TabReorderBehavior/>
								<behav:AttachDraggableTabsBehavior/>
							</i:Interaction.Behaviors>

							<TabControl.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding Header}" FontSize="14"/>
								</DataTemplate>
							</TabControl.ItemTemplate>

							<TabControl.ContentTemplate>
								<DataTemplate>
									<ContentControl Content="{Binding Content}" />
								</DataTemplate>
							</TabControl.ContentTemplate>
						</TabControl>
					</Border>
				</DataTemplate>
			</Setter.Value>
		</Setter>

		<!-- DockControlTopTabControl -->
		<Setter Property="DockControlTopTabControl">
			<Setter.Value>
				<DataTemplate>
					<Border Name="TopTabBorder" Padding="0" Margin="0">
						<TabControl
							ItemsSource="{Binding}"
							ClipToBounds="True"
							TabStripPlacement="Top"
							Padding="0"
							Margin="0">

							<i:Interaction.Behaviors>
								<behav:TabReorderBehavior/>
								<behav:AttachDraggableTabsBehavior/>
							</i:Interaction.Behaviors>

							<TabControl.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding Header}" FontSize="14"/>
								</DataTemplate>
							</TabControl.ItemTemplate>

							<TabControl.ContentTemplate>
								<DataTemplate>
									<ContentControl Content="{Binding Content}" />
								</DataTemplate>
							</TabControl.ContentTemplate>
						</TabControl>
					</Border>
				</DataTemplate>
			</Setter.Value>
		</Setter>

	</Style>

</Styles>